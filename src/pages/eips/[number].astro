---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const eips = await getCollection('eips');
  return eips.map((entry) => ({
    params: { number: String(entry.data.number) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const base = import.meta.env.BASE_URL;
const trackLabel = d.track === 'minimal' ? 'Minimal set' : 'Comprehensive alternative';
---

<Base title={`EIP-${d.number}: ${d.title}`} description={d.summary}>
  <article class="eip-page" style={`--accent-eip:${d.accent}`}>
    <div class="eip-hero">
      <div class="eip-hero-glow" aria-hidden="true"></div>
      <div class="container">
        <a class="back" href={`${base}/#${d.track === 'minimal' ? 'minimal' : 'eip-7999'}`}>← Back to overview</a>
        <div class="eip-tags">
          <span class="tag tag--track">{trackLabel}</span>
          <span class="tag">{d.needsReview ? 'Draft · needs verification' : `Status: ${d.status}`}</span>
        </div>
        <p class="eip-kicker">EIP-{d.number}</p>
        <h1>{d.title}</h1>
        <p class="eip-summary">{d.summary}</p>
        <div class="eip-chips">
          {d.highlights.map((h) => <span>{h}</span>)}
        </div>
        {d.specUrl && (
          <a class="btn btn--primary eip-spec-link" href={d.specUrl} target="_blank" rel="noopener">
            View the specification ↗
          </a>
        )}
      </div>
    </div>

    <div class="container eip-body">
      <div class="markdown prose">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .eip-hero { position: relative; overflow: hidden; padding: 2.5rem 0 2.75rem; border-bottom: 1px solid var(--border); }
  .eip-hero-glow {
    position: absolute; top: -60%; right: -10%;
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent-eip) 24%, transparent), transparent 70%);
    filter: blur(30px); z-index: 0; pointer-events: none;
  }
  .eip-hero .container { position: relative; z-index: 1; }
  .back { display: inline-block; color: var(--text-soft); font-size: 0.9rem; margin-bottom: 1.25rem; }
  .back:hover { color: var(--accent-ink); }
  .eip-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.9rem; }
  .tag {
    font-size: 0.74rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
    border: 1px solid var(--border); color: var(--text-faint);
    padding: 0.2rem 0.6rem; border-radius: 999px; background: var(--bg-elev);
  }
  .tag--track { color: var(--accent-eip); border-color: color-mix(in srgb, var(--accent-eip) 40%, var(--border)); }
  .eip-kicker { font-family: var(--font-mono); color: var(--accent-eip); font-weight: 600; margin: 0 0 0.25rem; }
  .eip-hero h1 { font-size: clamp(1.9rem, 4.5vw, 2.9rem); margin: 0 0 0.9rem; max-width: 22ch; }
  .eip-summary { font-size: 1.15rem; color: var(--text-soft); max-width: 62ch; margin: 0 0 1.25rem; }
  .eip-chips { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-bottom: 1.5rem; }
  .eip-chips span {
    font-size: 0.8rem; font-family: var(--font-mono);
    background: var(--bg-elev); border: 1px solid var(--border); color: var(--text-soft);
    padding: 0.22rem 0.6rem; border-radius: 7px;
  }
  .eip-body { padding: 2.75rem 1.5rem 1rem; }
  .markdown { margin: 0 auto; }
  .markdown :global(h2:first-child) { margin-top: 0; }
</style>
