---
interface Props {
  number: number;
  title: string;
  status: string;
  summary: string;
  highlights: string[];
  accent: string;
  href: string;
  index?: number;
  needsReview?: boolean;
}
const { number, title, status, summary, highlights, accent, href, index, needsReview } = Astro.props;
---

<a class="eip-card" href={href} style={`--card-accent:${accent}`}>
  <div class="eip-card-top">
    {index != null && <span class="eip-step">{index}</span>}
    <span class="eip-num">EIP-{number}</span>
    <span class="eip-status">{needsReview ? 'Draft · verify' : status}</span>
  </div>
  <h3 class="eip-title">{title}</h3>
  <p class="eip-summary">{summary}</p>
  {highlights.length > 0 && (
    <ul class="eip-chips">
      {highlights.slice(0, 4).map((h) => <li>{h}</li>)}
    </ul>
  )}
  <span class="eip-more">Read details →</span>
</a>

<style>
  .eip-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    color: var(--text);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .eip-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: var(--card-accent);
  }
  .eip-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--card-accent) 45%, var(--border));
    text-decoration: none;
  }
  .eip-card-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.9rem;
  }
  .eip-step {
    width: 26px; height: 26px;
    display: grid; place-items: center;
    border-radius: 8px;
    background: color-mix(in srgb, var(--card-accent) 16%, transparent);
    color: var(--card-accent);
    font-weight: 700; font-size: 0.85rem;
  }
  .eip-num {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--card-accent);
  }
  .eip-status {
    margin-left: auto;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-faint);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
  }
  .eip-title { font-size: 1.2rem; margin: 0 0 0.5rem; }
  .eip-summary { color: var(--text-soft); font-size: 0.96rem; margin: 0 0 1.1rem; flex: 1; }
  .eip-chips {
    list-style: none; padding: 0; margin: 0 0 1.1rem;
    display: flex; flex-wrap: wrap; gap: 0.4rem;
  }
  .eip-chips li {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    background: var(--bg-sunken);
    border: 1px solid var(--border);
    color: var(--text-soft);
    padding: 0.2rem 0.55rem;
    border-radius: 7px;
  }
  .eip-more {
    font-weight: 600; font-size: 0.92rem;
    color: var(--card-accent);
  }
</style>
