---
const year = 2026;
const links = [
  { label: 'Anchor analysis (ethresear.ch)', href: 'https://ethresear.ch/t/scaling-in-hegota-using-the-eth-transfer-to-anchor-execution-and-bandwidth/25232' },
  { label: 'EIP-8131', href: 'https://eips.ethereum.org/EIPS/eip-8131' },
  { label: 'EIP-8279', href: 'https://eips.ethereum.org/EIPS/eip-8279' },
  { label: 'EIP-7999 (PR #11835)', href: 'https://github.com/ethereum/EIPs/pull/11835' },
  { label: 'Compute repricing — fracgas', href: 'https://misilva73.github.io/hegota-compute-repricing/fracgas.html' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="footer-brand">Hegota <strong>Repricings</strong></p>
      <p class="footer-note">
        A community explainer of the gas-repricing EIPs that let Ethereum scale to 450M gas.
        Not an official Ethereum Foundation page.
      </p>
    </div>
    <nav class="footer-links" aria-label="Resources">
      <span class="footer-links-title">Sources</span>
      {links.map((l) => <a href={l.href} target="_blank" rel="noopener">{l.label}</a>)}
    </nav>
  </div>
  <div class="container footer-base">
    <span>© {year} · Built with Astro · Deployed on GitHub Pages</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-sunken);
    padding: 3rem 0 2rem;
    margin-top: 2rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
  }
  .footer-brand { font-size: 1.1rem; margin-bottom: 0.4rem; }
  .footer-brand strong { color: var(--accent-ink); }
  .footer-note { color: var(--text-soft); font-size: 0.92rem; max-width: 42ch; }
  .footer-links { display: flex; flex-direction: column; gap: 0.45rem; }
  .footer-links-title {
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-faint); margin-bottom: 0.3rem;
  }
  .footer-links a { color: var(--text-soft); font-size: 0.92rem; }
  .footer-links a:hover { color: var(--accent-ink); }
  .footer-base {
    margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border);
    color: var(--text-faint); font-size: 0.85rem;
  }
  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; gap: 1.75rem; }
  }
</style>
